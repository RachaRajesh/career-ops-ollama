# =============================================================================
# Career-Ops (Ollama Edition) — environment config
# Copy this file to .env and edit. Nothing here is secret; it's all local.
# =============================================================================

# --- Ollama server ---
# The default is the local Ollama server started by `ollama serve`.
# If you run Ollama on another machine or port, change this.
OLLAMA_HOST=http://localhost:11434

# The model to use for evaluations, PDF keyword injection, and form filling.
# Pull it first with: ollama pull <name>
#
# Suggestions:
#   llama3.1:8b         — fast, low memory (~5GB), okay reasoning
#   qwen2.5:14b         — better at structured output and scoring (~9GB)
#   deepseek-r1:14b     — strongest reasoning, a bit slower (~9GB)
#   qwen2.5:32b         — if you have the VRAM, this is closest to frontier
OLLAMA_MODEL=llama3.1:8b

# Per-request timeout. Bump this if you're on CPU-only inference with a big model.
OLLAMA_TIMEOUT_MS=120000

# Lower temperature = more consistent scoring. 0.2–0.4 is the sweet spot for
# evaluation tasks. For cover letters / outreach, the apply script uses 0.7.
OLLAMA_TEMPERATURE=0.3

# Context window the model was loaded with. Must be ≤ what the model supports.
# llama3.1 supports 128k but defaults to 8k; bump this to handle long JDs.
OLLAMA_NUM_CTX=16384

# --- Auto-apply behavior ---
# Keep this `false` so you can watch Playwright fill the form and catch mistakes.
AUTO_APPLY_HEADLESS=false

# If you set this to `false`, the apply script will STILL not submit — it just
# won't pause for your confirmation. The actual submit click is not implemented.
# This flag exists for future use; today it does nothing destructive.
AUTO_APPLY_REQUIRE_CONFIRM=true

# How long to keep the browser open after filling (ms). Gives you time to review.
AUTO_APPLY_REVIEW_TIMEOUT_MS=600000

# --- Paths (usually fine as-is) ---
CV_PATH=./cv.md
PROFILE_PATH=./config/profile.yml
MODES_DIR=./modes
REPORTS_DIR=./reports
OUTPUT_DIR=./output
DATA_DIR=./data
