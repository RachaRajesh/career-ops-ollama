# =============================================================================
# Career-Ops (Ollama Edition) — environment config
# Copy this file to .env and edit. Nothing here is secret; it's all local.
# =============================================================================

# --- LLM provider selection ---
# Which backend should career-ops talk to?
#   "ollama"     — direct to local Ollama server. Reliable, what this project
#                  was built around. Recommended default.
#   "openclaude" — route through openclaude's OpenAI-compatible API
#                  (https://github.com/Gitlawb/openclaude). Useful if you want
#                  to unify routing across many providers (OpenAI, DeepSeek,
#                  Gemini, Ollama) behind one endpoint. See docs/OPENCLAUDE.md.
LLM_PROVIDER=ollama

# --- Ollama (used when LLM_PROVIDER=ollama) ---
OLLAMA_HOST=http://localhost:11434

# The model to use. Pull it first with: ollama pull <name>
#   qwen2.5:14b         — recommended default, strong JSON reliability (~9GB)
#   qwen2.5:32b         — best quality if you have the RAM (~20GB, 48GB Mac fine)
#   llama3.1:8b         — fast fallback (~5GB)
#   deepseek-r1:14b     — strong reasoning but CoT can bloat JSON (~9GB)
OLLAMA_MODEL=qwen2.5:32b

# Per-request timeout. Bump for big models on CPU.
OLLAMA_TIMEOUT_MS=300000

# Lower = more consistent scoring. 0.2-0.4 is the sweet spot for evaluation.
OLLAMA_TEMPERATURE=0.3

# Context window. Must be ≤ what the model supports. 32768 handles long JDs
# plus full CV plus profile without truncation for Qwen 2.5 and Llama 3.1.
OLLAMA_NUM_CTX=32768

# --- openclaude (used when LLM_PROVIDER=openclaude) ---
# Only needed if LLM_PROVIDER=openclaude. See docs/OPENCLAUDE.md for setup.
#
# Base URL of openclaude's OpenAI-compatible HTTP server.
OPENCLAUDE_BASE_URL=http://localhost:3000/v1

# Model name as it's configured inside openclaude. If openclaude is routed to
# Ollama's qwen2.5:14b, this should be "qwen2.5:14b". If it's routed to a
# cloud provider through openclaude's proxy, use that provider's model name.
# If empty, falls back to OLLAMA_MODEL above.
OPENCLAUDE_MODEL=

# API key — only needed if your openclaude config proxies to a cloud provider.
# For local-only routing (Ollama through openclaude), leave blank.
OPENCLAUDE_API_KEY=

# --- Auto-apply behavior ---
AUTO_APPLY_HEADLESS=false
AUTO_APPLY_REQUIRE_CONFIRM=true
AUTO_APPLY_REVIEW_TIMEOUT_MS=600000

# --- Auto-apply credentials (for sign-in/sign-up gates) ---
# If set, the script will fill email + password on sign-in forms automatically.
# Leave blank to skip auth auto-fill.
#
# ⚠ SECURITY: This file is gitignored. Never commit your real password to git.
# ⚠ Use an app-specific password for job boards, not your main Gmail password.
APPLY_EMAIL=racharajeshai@gmail.com
APPLY_PASSWORD=Gmaillogin@123

# --- Paths (usually fine as-is) ---
CV_PATH=./cv.md
PROFILE_PATH=./config/profile.yml
MODES_DIR=./modes
REPORTS_DIR=./reports
OUTPUT_DIR=./output
DATA_DIR=./data
